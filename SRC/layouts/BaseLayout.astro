---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

const { title = "WholeHearted", description = "WholeHearted.live", index = false } = Astro.props;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={description} />

  <!-- Search engine indexing: controlled per-page via `index` prop -->
  <meta name="robots" content={index ? "index, follow" : "noindex, nofollow"} />

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap"
    rel="stylesheet"
  />
  <link
    href="https://fonts.googleapis.com/css2?family=Libre+Baskerville:wght@400;700&display=swap"
    rel="stylesheet"
  />

  <title>{title}</title>

  <!-- GoHighLevel tracking -->
  <script
    src="https://link.msgsndr.com/js/external-tracking.js"
    data-tracking-id="tk_252c40d4690b453f9f9795810f909b8f"
  ></script>
</head>

  <body class="min-h-screen text-ink">
    <Header />
    <main class="mx-auto max-w-6xl px-4 py-10">
      <slot />
    </main>

    <Footer />

    <!-- GoHighLevel Chat Widget -->
    <script src="https://widgets.leadconnectorhq.com/loader.js" data-resources-url="https://widgets.leadconnectorhq.com/chat-widget/loader.js" data-widget-id="69dc1df59f3b6f8188df315e" is:inline></script>
  </body>
</html>

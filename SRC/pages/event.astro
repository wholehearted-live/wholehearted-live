---
import EventLayout from "../layouts/EventLayout.astro";
import { LINKS } from "../data/links";
---

<EventLayout
  title="Free Event — Dr. Kenny | Metabolic Reset | April 29 · Dayton, OH | WholeHearted"
  description="Join Dr. Kenny (Chiropractor) on April 29th at 6pm in Dayton, OH. Discover how a simple nutraceutical can help with Diabetes, High BP, Cholesterol, PCOS, Weight, Brain Fog & more."
>

  <!-- ============================================================
       FACEBOOK PIXEL  — replace YOUR_PIXEL_ID
  ============================================================== -->

  ============================================================== -->
  <script is:inline>
    // ── Pixel helpers ─────────────────────────────────────────
    function trackFB(event, params) {
      if (typeof fbq !== 'undefined') fbq('track', event, params || {});
    }
    function trackTT(event, params) {
      if (typeof ttq !== 'undefined') ttq.track(event, params || {});
    }

    // ── Countdown to April 29, 2025 6pm ET ────────────────────
    function updateCountdown() {
      var target = new Date('2025-04-29T18:00:00-04:00').getTime();
      var now = new Date().getTime();
      var diff = target - now;
      var el = document.getElementById('countdown');
      if (!el) return;
      if (diff <= 0) { el.textContent = 'Tonight at 6pm!'; return; }
      var d = Math.floor(diff/(1000*60*60*24));
      var h = Math.floor((diff%(1000*60*60*24))/(1000*60*60));
      var m = Math.floor((diff%(1000*60*60))/(1000*60));
      var s = Math.floor((diff%(1000*60))/1000);
      el.textContent = d+'d '+h+'h '+m+'m '+s+'s until event';
    }
    updateCountdown();
    setInterval(updateCountdown, 1000);

    // ── Quiz submit ────────────────────────────────────────────
    function submitQuiz(e) {
      e.preventDefault();
      trackFB('Lead', { content_name: 'Metabolic Quiz' });
      trackTT('SubmitForm', { content_name: 'Metabolic Quiz' });
      document.getElementById('quiz-wrapper').style.display = 'none';
      document.getElementById('quiz-result').style.display = 'block';
    }

    // ── Register submit ────────────────────────────────────────
    function submitRegister(e) {
      e.preventDefault();
      trackFB('CompleteRegistration', { content_name: 'April 29 Event', content_category: 'Event' });
      trackTT('CompleteRegistration', { content_name: 'April 29 Event' });
      document.getElementById('register-wrapper').style.display = 'none';
      document.getElementById('register-result').style.display = 'block';
      document.getElementById('register-result').scrollIntoView({ behavior: 'smooth' });
    }

    // ── Scroll depth tracking ──────────────────────────────────
    var tracked50 = false, trackedReg = false;
    window.addEventListener('scroll', function() {
      var pct = (window.scrollY/(document.body.scrollHeight-window.innerHeight))*100;
      if (!tracked50 && pct >= 50) { trackFB('ViewContent',{content_name:'50% scroll'}); tracked50=true; }
      var reg = document.getElementById('register');
      if (!trackedReg && reg && reg.getBoundingClientRect().top < window.innerHeight) {
        trackFB('ViewContent',{content_name:'Reached Registration'}); trackedReg=true;
      }
    });

    // ── Social share ───────────────────────────────────────────
    function shareFacebook() {
      var url = encodeURIComponent(window.location.href);
      var txt = encodeURIComponent('FREE Health Event with Dr. Kenny – April 29 in Dayton, OH! Diabetes, High BP, Cholesterol, Weight & more. Register at WholeHearted.live/event');
      window.open('https://www.facebook.com/sharer/sharer.php?u='+url+'&quote='+txt, '_blank','width=620,height=420');
      trackFB('Share');
    }
    function shareInstagram() {
      alert('To share on Instagram:\n\nCopy this link and paste it in your bio, story, or DM!\n\n'+window.location.href);
    }
    function shareTikTok() {
      alert('To share on TikTok:\n\nCopy this link and drop it in your bio or video caption!\n\n'+window.location.href);
    }

    // ── FAQ open/close toggle icon ─────────────────────────────
    document.querySelectorAll('details').forEach(function(d) {
      d.addEventListener('toggle', function() {
        var icon = d.querySelector('summary span:last-child');
        if (icon) icon.textContent = d.open ? '−' : '+';
      });
    });
  </script>


  <style>
    /* Urgency banner */
    .urgency-bar {
      background: linear-gradient(90deg, #7a1f2b, #f43f5e, #7a1f2b);
      color: white;
      text-align: center;
      padding: 12px 20px;
      font-weight: 700;
      font-size: 0.9rem;
      letter-spacing: 0.02em;
      border-radius: 12px;
      margin-bottom: 2rem;
    }
    /* Countdown */
    #countdown { font-weight: 900; font-size: 1.05rem; }

    /* Condition pill */
    .condition-pill {
      display: flex; align-items: center; gap: 8px;
      background: rgba(255,255,255,0.7);
      border: 1px solid rgba(244,63,94,0.2);
      border-left: 3px solid #f43f5e;
      border-radius: 10px;
      padding: 10px 14px;
      font-size: 0.9rem;
      font-weight: 600;
      color: #0f172a;
      backdrop-filter: blur(6px);
    }

    /* Stat box */
    .stat-box {
      background: rgba(255,255,255,0.7);
      border: 1px solid rgba(15,23,42,0.08);
      border-radius: 16px;
      padding: 20px;
      text-align: center;
      backdrop-filter: blur(8px);
    }

    /* Quiz option */
    .quiz-opt {
      display: flex; align-items: center; gap: 10px;
      background: rgba(255,255,255,0.7);
      border: 1px solid rgba(15,23,42,0.1);
      border-radius: 10px;
      padding: 12px 16px;
      cursor: pointer;
      font-size: 0.92rem;
      color: #0f172a;
      transition: border-color 0.2s, background 0.2s;
    }
    .quiz-opt:hover { border-color: #f43f5e; background: rgba(244,63,94,0.05); }
    .quiz-opt input[type="radio"] { accent-color: #f43f5e; width: 16px; height: 16px; flex-shrink: 0; }

    /* Learn card */
    .learn-card {
      background: rgba(255,255,255,0.65);
      border: 1px solid rgba(15,23,42,0.08);
      border-radius: 20px;
      padding: 28px 24px;
      box-shadow: 0 8px 24px rgba(0,0,0,0.05);
    }

    /* Social share buttons */
    .soc-btn {
      display: inline-flex; align-items: center; gap: 8px;
      padding: 10px 20px; border-radius: 10px;
      font-weight: 700; font-size: 0.88rem;
      border: none; cursor: pointer;
      transition: opacity 0.2s;
    }
    .soc-btn:hover { opacity: 0.85; }

    /* Result screens */
    .result-screen { display: none; text-align: center; padding: 16px 0; }

    /* Fade in animations */
    @keyframes fadeUp {
      from { opacity:0; transform: translateY(16px); }
      to   { opacity:1; transform: translateY(0); }
    }
    .fade-up { animation: fadeUp 0.6s ease forwards; }
  </style>

  <!-- ============================================================
       URGENCY BANNER
  ============================================================== -->
  <div class="urgency-bar">
    🔥 FREE In-Person Event &nbsp;·&nbsp; Wednesday April 29 @ 6pm &nbsp;·&nbsp; Dayton, OH &nbsp;|&nbsp;
    <span id="countdown">Limited seats — register now!</span>
  </div>

  <!-- ============================================================
       HERO
  ============================================================== -->
  <section class="relative overflow-hidden py-16 md:py-20 fade-up">
    <!-- Background glow -->
    <div class="pointer-events-none absolute inset-0 flex items-start justify-center">
      <div class="mt-20 h-96 w-96 rounded-full bg-rose/10 blur-3xl"></div>
    </div>

    <div class="relative text-center max-w-3xl mx-auto">
      <span class="inline-block rounded-full bg-wine/10 px-4 py-1.5 text-xs font-bold uppercase tracking-widest text-wine mb-5">
        Free In-Person Event — April 29th · Dayton, OH
      </span>

      <h1 class="brand-font text-4xl md:text-5xl text-ink tracking-tight leading-tight mb-4">
        Are You Struggling With<br>
        <span class="text-rose">Diabetes, High BP, Weight,</span><br>
        or Other Chronic Conditions?
      </h1>

      <span class="mx-auto block h-1.5 w-24 rounded-full bg-wine/40 mb-6"></span>

      <p class="text-ink/70 text-lg max-w-2xl mx-auto mb-8">
        Come hear <strong class="text-ink">Dr. Kenny</strong> — Chiropractor and metabolic health educator —
        present how <strong class="text-ink">a simple nutraceutical</strong> can empower you to transform your
        health from the inside out. Faith-centered. Science-backed. Completely free.
      </p>

      <!-- Event chips -->
      <div class="flex flex-wrap gap-3 justify-center mb-10">
        <div class="flex items-center gap-2 rounded-full border border-ink/15 bg-white/70 px-4 py-2 text-sm font-semibold text-ink backdrop-blur-sm">
          📅 Wednesday, April 29th
        </div>
        <div class="flex items-center gap-2 rounded-full border border-ink/15 bg-white/70 px-4 py-2 text-sm font-semibold text-ink backdrop-blur-sm">
          🕕 6:00 PM
        </div>
        <div class="flex items-center gap-2 rounded-full border border-ink/15 bg-white/70 px-4 py-2 text-sm font-semibold text-ink backdrop-blur-sm">
          📍 Holiday Inn Express · Dayton, OH
        </div>
        <div class="flex items-center gap-2 rounded-full border border-rose/40 bg-rose/10 px-4 py-2 text-sm font-bold text-rose backdrop-blur-sm">
          🎟️ FREE — Limited Seats
        </div>
      </div>

      <a
        href="#register"
        onclick="trackFB('InitiateCheckout',{content_name:'Hero CTA'})"
        class="inline-flex items-center justify-center rounded-xl bg-rose px-9 py-4 text-white font-bold text-lg transition hover:bg-rose/85 shadow-lg shadow-rose/25"
      >
        Reserve My Free Seat →
      </a>

      <p class="mt-4 text-sm text-ink/50">
        ⚠️ Seats are <strong class="text-ink/70">strictly limited.</strong> Reserve yours before they're gone.
      </p>
    </div>
  </section>

  <!-- Divider -->
  <div class="mx-auto my-10 h-px max-w-3xl bg-gradient-to-r from-transparent via-wine/30 to-transparent"></div>

  <!-- ============================================================
       SOCIAL SHARE
  ============================================================== -->
  <div class="my-6 flex flex-wrap items-center justify-center gap-3 text-sm text-ink/60">
    <span class="font-semibold text-ink/70">Know someone who needs this? Share:</span>
    <button class="soc-btn" style="background:#1877F2;color:white;" onclick="shareFacebook()">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="white"><path d="M24 12.07C24 5.41 18.63 0 12 0S0 5.4 0 12.07C0 18.1 4.39 23.1 10.13 24v-8.44H7.08v-3.49h3.04V9.41c0-3.02 1.8-4.7 4.54-4.7 1.31 0 2.68.24 2.68.24v2.97h-1.51c-1.49 0-1.95.93-1.95 1.88v2.26h3.32l-.53 3.5h-2.79V24C19.62 23.1 24 18.1 24 12.07"/></svg>
      Facebook
    </button>
    <button class="soc-btn" style="background:linear-gradient(135deg,#f58529,#dd2a7b,#8134af,#515bd4);color:white;" onclick="shareInstagram()">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="white"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
      Instagram
    </button>
    <button class="soc-btn" style="background:#010101;color:white;border:1px solid #333;" onclick="shareTikTok()">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="white"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.18 8.18 0 004.79 1.53V6.77a4.85 4.85 0 01-1.02-.08z"/></svg>
      TikTok
    </button>
  </div>

  <!-- Divider -->
  <div class="mx-auto my-10 h-px max-w-3xl bg-gradient-to-r from-transparent via-wine/30 to-transparent"></div>

  <!-- ============================================================
       CONDITIONS
  ============================================================== -->
  <section class="py-12">
    <div class="text-center mb-10">
      <p class="text-sm font-bold uppercase tracking-widest text-wine mb-3">You're In the Right Place If…</p>
      <h2 class="brand-font text-3xl md:text-4xl text-ink">
        Are Any of These <span class="text-rose">Affecting You or Someone You Love?</span>
      </h2>
      <p class="mt-4 text-ink/60 max-w-xl mx-auto">
        These conditions may look different on the surface — but Dr. Kenny will reveal how they often share the same metabolic root cause.
      </p>
    </div>

    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3 max-w-4xl mx-auto">
      <div class="condition-pill"><span>🩸</span> Diabetes</div>
      <div class="condition-pill"><span>💓</span> High Blood Pressure</div>
      <div class="condition-pill"><span>📊</span> High Cholesterol</div>
      <div class="condition-pill"><span>🔄</span> PCOS</div>
      <div class="condition-pill"><span>⚖️</span> Weight Challenges</div>
      <div class="condition-pill"><span>😴</span> Poor Sleep</div>
      <div class="condition-pill"><span>🫀</span> Fatty Liver</div>
      <div class="condition-pill"><span>👂</span> Tinnitus</div>
      <div class="condition-pill"><span>🏷️</span> Skin Tags</div>
      <div class="condition-pill"><span>🌿</span> Eczema</div>
      <div class="condition-pill"><span>🧠</span> Brain Fog</div>
      <div class="condition-pill"><span>⚡</span> Fatigue</div>
    </div>
  </section>

  <!-- Divider -->
  <div class="mx-auto my-10 h-px max-w-3xl bg-gradient-to-r from-transparent via-wine/30 to-transparent"></div>

  <!-- ============================================================
       DR. KENNY
  ============================================================== -->
  <section class="py-12">
    <div class="text-center mb-8">
      <p class="text-sm font-bold uppercase tracking-widest text-wine mb-3">Your Speaker</p>
      <h2 class="brand-font text-3xl md:text-4xl text-ink">Meet <span class="text-rose">Dr. Kenny</span></h2>
    </div>

    <div class="surface max-w-3xl mx-auto px-8 py-10">
      <div class="flex flex-col sm:flex-row gap-8 items-start">
        <!-- Dr. Kenny's headshot -->
        <div class="shrink-0 mx-auto sm:mx-0">
          <img
            src="/Dr-Kenny.png"
            alt="Dr. Kenny — Chiropractor & Metabolic Health Educator"
            width="144"
            height="144"
            class="h-36 w-36 rounded-full object-cover object-top border-4"
            style="border-color:#c6a85d;"
          />
          <p class="mt-2 text-center text-xs text-ink/50 italic">Dr. Kenny</p>
        </div>
        <div>
          <h3 class="brand-font text-2xl text-ink mb-1">Dr. Kenny</h3>
          <p class="text-sm font-bold uppercase tracking-widest mb-4" style="color:#c6a85d;">
            Chiropractor &amp; Metabolic Health Educator
          </p>
          <p class="text-ink/70 mb-5">
            Dr. Kenny has spent his career looking beyond symptoms to find the root causes of chronic illness.
            As a chiropractor with a deep passion for metabolic health, he combines structural and nutritional
            science to help patients reclaim their vitality — naturally. His talks have helped hundreds of
            families take their first real steps toward lasting change.
          </p>
          <ul class="space-y-2 text-sm text-ink/70">
            <li class="flex gap-2"><span class="text-sage font-bold">✓</span> Evidence-based approach to metabolic dysfunction</li>
            <li class="flex gap-2"><span class="text-sage font-bold">✓</span> Expert in the Unicity Feel Great nutraceutical system</li>
            <li class="flex gap-2"><span class="text-sage font-bold">✓</span> Faith-informed, whole-person wellness perspective</li>
            <li class="flex gap-2"><span class="text-sage font-bold">✓</span> Real patient results across chronic conditions</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Divider -->
  <div class="mx-auto my-10 h-px max-w-3xl bg-gradient-to-r from-transparent via-wine/30 to-transparent"></div>

  <!-- ============================================================
       WHAT YOU'LL LEARN
  ============================================================== -->
  <section class="py-12">
    <div class="text-center mb-10">
      <p class="text-sm font-bold uppercase tracking-widest text-wine mb-3">Inside the Event</p>
      <h2 class="brand-font text-3xl md:text-4xl text-ink">What Dr. Kenny Will Reveal</h2>
    </div>

    <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-5 max-w-4xl mx-auto">
      <div class="learn-card">
        <div class="h-10 w-10 rounded-xl flex items-center justify-center bg-rose/15 text-rose font-black text-lg mb-3">1</div>
        <h3 class="font-bold text-ink mb-2">The Metabolic Root Cause</h3>
        <p class="text-sm text-ink/65">Why Diabetes, High BP, Fatty Liver and more often share the same origin — and why treating symptoms alone never works.</p>
      </div>
      <div class="learn-card">
        <div class="h-10 w-10 rounded-xl flex items-center justify-center bg-rose/15 text-rose font-black text-lg mb-3">2</div>
        <h3 class="font-bold text-ink mb-2">The Nutraceutical Breakthrough</h3>
        <p class="text-sm text-ink/65">How the Unicity Feel Great System is helping people reverse metabolic dysfunction — backed by published clinical studies.</p>
      </div>
      <div class="learn-card">
        <div class="h-10 w-10 rounded-xl flex items-center justify-center bg-rose/15 text-rose font-black text-lg mb-3">3</div>
        <h3 class="font-bold text-ink mb-2">Insulin &amp; the Fat Connection</h3>
        <p class="text-sm text-ink/65">The hormone silently blocking your body from burning fat — even if you're eating well and exercising.</p>
      </div>
      <div class="learn-card">
        <div class="h-10 w-10 rounded-xl flex items-center justify-center bg-sage/20 text-sage font-black text-lg mb-3">4</div>
        <h3 class="font-bold text-ink mb-2">Real Patient Transformations</h3>
        <p class="text-sm text-ink/65">Before-and-after results: A1C drops, weight loss, cleared brain fog, normalized cholesterol — from real people.</p>
      </div>
      <div class="learn-card">
        <div class="h-10 w-10 rounded-xl flex items-center justify-center bg-sage/20 text-sage font-black text-lg mb-3">5</div>
        <h3 class="font-bold text-ink mb-2">Your Action Plan</h3>
        <p class="text-sm text-ink/65">Leave with a clear, practical protocol you can begin that same week — no extreme diets or hours of exercise required.</p>
      </div>
      <div class="learn-card">
        <div class="h-10 w-10 rounded-xl flex items-center justify-center bg-gold/20 font-black text-lg mb-3" style="color:#c6a85d;">6</div>
        <h3 class="font-bold text-ink mb-2">Live Q&amp;A with Dr. Kenny</h3>
        <p class="text-sm text-ink/65">Get your personal health questions answered directly — in a warm, open, faith-centered setting.</p>
      </div>
    </div>
  </section>

  <!-- Divider -->
  <div class="mx-auto my-10 h-px max-w-3xl bg-gradient-to-r from-transparent via-wine/30 to-transparent"></div>

  <!-- ============================================================
       STATS / SCIENCE
  ============================================================== -->
  <section class="py-12">
    <div class="rounded-3xl bg-sage/15 px-8 py-12">
      <div class="text-center mb-8">
        <p class="text-sm font-bold uppercase tracking-widest text-wine mb-2">Clinical Research</p>
        <h2 class="brand-font text-2xl md:text-3xl text-ink">The Science Behind the System</h2>
        <p class="mt-2 text-sm text-ink/60 max-w-lg mx-auto">
          Published clinical validation studies on the Unicity Feel Great System show significant improvements in metabolic health markers.
        </p>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 max-w-3xl mx-auto">
        <div class="stat-box">
          <div class="brand-font text-3xl text-rose mb-1">12%</div>
          <div class="text-xs text-ink/60">Reduction in Glycemic Variability</div>
        </div>
        <div class="stat-box">
          <div class="brand-font text-3xl text-rose mb-1">↓ HbA1c</div>
          <div class="text-xs text-ink/60">Improved Blood Sugar Control</div>
        </div>
        <div class="stat-box">
          <div class="brand-font text-3xl text-rose mb-1">↓ BMI</div>
          <div class="text-xs text-ink/60">Weight &amp; Waist Circumference</div>
        </div>
        <div class="stat-box">
          <div class="brand-font text-3xl text-rose mb-1">↓ Triglyc.</div>
          <div class="text-xs text-ink/60">Improved Cholesterol &amp; Lipids</div>
        </div>
      </div>
      <p class="text-center text-xs text-ink/40 mt-6">* Published clinical studies. Individual results vary. Not medical advice.</p>
    </div>
  </section>

  <!-- Divider -->
  <div class="mx-auto my-10 h-px max-w-3xl bg-gradient-to-r from-transparent via-wine/30 to-transparent"></div>

  <!-- ============================================================
       QUIZ
  ============================================================== -->
  <section class="py-12" id="quiz">
    <div class="surface max-w-2xl mx-auto px-8 py-10">
      <div id="quiz-wrapper">
        <p class="text-xs font-bold uppercase tracking-widest text-sage mb-3">Free 60-Second Assessment</p>
        <h2 class="brand-font text-2xl md:text-3xl text-ink mb-2">Is Your Metabolism <span class="text-rose">Working Against You?</span></h2>
        <p class="text-ink/60 text-sm mb-8">Answer 4 quick questions to see whether this event is right for you — and we'll send you your personalized result.</p>

        <form id="quizForm" onsubmit="submitQuiz(event)" class="space-y-6">
          <div>
            <p class="font-semibold text-ink text-sm mb-3">1. How's your energy throughout the day?</p>
            <div class="flex flex-col gap-2">
              <label class="quiz-opt"><input type="radio" name="q1" value="a" required> I crash after meals or in the afternoon</label>
              <label class="quiz-opt"><input type="radio" name="q1" value="b"> I feel tired most of the time regardless</label>
              <label class="quiz-opt"><input type="radio" name="q1" value="c"> My energy is generally stable</label>
            </div>
          </div>
          <div>
            <p class="font-semibold text-ink text-sm mb-3">2. Has a doctor mentioned any of these?</p>
            <div class="flex flex-col gap-2">
              <label class="quiz-opt"><input type="radio" name="q2" value="a" required> Pre-diabetes, insulin resistance, or Type 2 diabetes</label>
              <label class="quiz-opt"><input type="radio" name="q2" value="b"> High BP, high cholesterol, or fatty liver</label>
              <label class="quiz-opt"><input type="radio" name="q2" value="c"> None of the above</label>
            </div>
          </div>
          <div>
            <p class="font-semibold text-ink text-sm mb-3">3. What's your current weight situation?</p>
            <div class="flex flex-col gap-2">
              <label class="quiz-opt"><input type="radio" name="q3" value="a" required> I'm gaining weight without changing my diet</label>
              <label class="quiz-opt"><input type="radio" name="q3" value="b"> I can't lose weight no matter what I try</label>
              <label class="quiz-opt"><input type="radio" name="q3" value="c"> My weight has been stable and healthy</label>
            </div>
          </div>
          <div>
            <p class="font-semibold text-ink text-sm mb-3">4. Do you experience brain fog, poor sleep, or sugar cravings?</p>
            <div class="flex flex-col gap-2">

---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="About — WholeHearted" description="Why WholeHearted exists and where it's going.">
  <!-- Hero Section -->
  <section class="relative overflow-hidden py-20 -mx-4 px-4">
    <div class="absolute inset-0 -z-10 bg-gradient-to-r from-rose/15 via-ivory via-50% to-sage/10"></div>
    <div class="text-center max-w-3xl mx-auto">
      <p class="text-sm font-medium text-wine uppercase tracking-wide mb-4">Our Story</p>
      <h1 class="brand-font text-4xl md:text-5xl font-medium tracking-tight text-ink">
        Living Wholeheartedly
      </h1>
      <span class="mx-auto mt-4 block h-1.5 w-24 rounded-full bg-wine"></span>
      <p class="mt-6 max-w-xl text-base text-ink/70 mx-auto">
        More than a brand — a commitment to nurturing body, mind, and spirit through
        faith-centered wellness and genuine community.
      </p>
    </div>
  </section>

  <!-- Mission Section -->
  <section class="py-16">
    <div class="max-w-3xl mx-auto">
      <h2 class="brand-font text-2xl md:text-3xl font-medium text-ink mb-6">Why WholeHearted?</h2>
      <p class="text-ink/70 leading-relaxed mb-6">
        WholeHearted was born from a simple belief: true wellness isn't just about what we put in our bodies —
        it's about how we live, who we walk with, and Whose we are.
      </p>
      <p class="text-ink/70 leading-relaxed mb-6">
        In a world full of quick fixes and empty promises, we wanted to create something different.
        A space where faith and wellness meet. Where education empowers rather than overwhelms.
        Where community means showing up for each other — not just scrolling past.
      </p>
      <p class="text-ink/70 leading-relaxed">
        We partner with Unicity because we believe in their science-backed approach to metabolic health.
        But products are just one piece. The real transformation happens when we commit to living
        wholeheartedly — together.
      </p>
    </div>
  </section>

  <!-- Brand ribbon divider -->
  <div class="mx-auto my-8 h-px max-w-3xl bg-gradient-to-r from-transparent via-wine/30 to-transparent"></div>

  <!-- Values Section -->
  <section class="py-16">
    <div class="rounded-3xl bg-sage/15 py-16 px-8">
      <h2 class="brand-font text-2xl md:text-3xl font-medium text-ink text-center mb-12">
        What We Stand For
      </h2>
      <div class="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto">
        <!-- Value 1 -->
        <div class="flex gap-4">
          <div class="h-12 w-12 shrink-0 flex items-center justify-center rounded-2xl bg-rose/20 text-rose text-xl">
            ♥
          </div>
          <div>
            <h3 class="text-lg font-semibold text-ink mb-1">Faith First</h3>
            <p class="text-ink/70 text-sm">
              Everything we do is rooted in faith. We believe lasting wellness starts with a whole heart aligned with God's purpose.
            </p>
          </div>
        </div>

        <!-- Value 2 -->
        <div class="flex gap-4">
          <div class="h-12 w-12 shrink-0 flex items-center justify-center rounded-2xl bg-sage/25 text-sage text-xl">
            ✓
          </div>
          <div>
            <h3 class="text-lg font-semibold text-ink mb-1">Integrity Always</h3>
            <p class="text-ink/70 text-sm">
              No gimmicks, no hype. We share what works, recommend what we use, and tell the truth — even when it's not easy.
            </p>
          </div>
        </div>

        <!-- Value 3 -->
        <div class="flex gap-4">
          <div class="h-12 w-12 shrink-0 flex items-center justify-center rounded-2xl bg-gold/20 text-gold text-xl">
            ✦
          </div>
          <div>
            <h3 class="text-lg font-semibold text-ink mb-1">Education Over Sales</h3>
            <p class="text-ink/70 text-sm">
              We teach, we share, we answer questions. An informed community makes better choices — and that's the goal.
            </p>
          </div>
        </div>

        <!-- Value 4 -->
        <div class="flex gap-4">
          <div class="h-12 w-12 shrink-0 flex items-center justify-center rounded-2xl bg-rose/15 text-rose text-xl">
            ❋
          </div>
          <div>
            <h3 class="text-lg font-semibold text-ink mb-1">Real Community</h3>
            <p class="text-ink/70 text-sm">
              Not followers — family. We show up, we encourage, we celebrate wins together. This journey is better shared.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Quote/Scripture Section -->
  <section class="py-16">
    <div class="max-w-2xl mx-auto text-center">
      <div class="mx-auto my-8 h-px max-w-xs bg-gradient-to-r from-transparent via-wine/30 to-transparent"></div>
      <blockquote class="brand-font text-2xl md:text-3xl font-medium text-ink italic">
        "Love the Lord your God with all your heart and with all your soul and with all your strength."
      </blockquote>
      <p class="mt-4 text-ink/50 text-sm">Deuteronomy 6:5</p>
      <div class="mx-auto my-8 h-px max-w-xs bg-gradient-to-r from-transparent via-wine/30 to-transparent"></div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16">
    <div class="rounded-3xl bg-sage/20 py-20 px-8 text-center">
      <h2 class="brand-font text-2xl md:text-3xl font-medium text-ink mb-4">
        Ready to join the journey?
      </h2>
      <p class="text-ink/70 max-w-xl mx-auto mb-8">
        Whether you're curious about wellness, looking for community, or ready to dive in —
        we'd love to have you.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/live"
          class="inline-flex items-center justify-center rounded-xl bg-rose px-7 py-3 text-white font-semibold hover:bg-rose/85 transition shadow-lg shadow-rose/25"
        >
          Watch Live
        </a>
        <a
          href="/shop"
          class="inline-flex items-center justify-center rounded-xl border border-ink/30 px-7 py-3 text-ink hover:bg-ink/5 transition"
        >
          Explore Products
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

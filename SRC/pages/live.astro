---
import BaseLayout from "../layouts/BaseLayout.astro";

const isLive = false; // flip to true when you go live
const nextLive = "Tonight • 8:00 PM ET";
const liveTitle = "Wholehearted Live";
const liveSubtitle =
  "Live education, Q&A, and encouragement — wellness for body and spirit.";
---

<BaseLayout title="Live | Wholehearted" description="Watch live streams and replays.">
  <section class="relative overflow-hidden bg-linear-to-b from-ivory via-ivory to-white">
    <!-- background glow -->
    <div class="pointer-events-none absolute inset-0">
      <div class="absolute -top-24 left-1/2 h-[520px] w-[520px] -translate-x-1/2 rounded-full bg-rose/12 blur-3xl"></div>
      <div class="absolute top-40 right-[-120px] h-[420px] w-[420px] rounded-full bg-sage/10 blur-3xl"></div>
    </div>

    <div class="relative mx-auto max-w-6xl px-6 pt-10 pb-16 md:pt-14">
      <div class="grid gap-10 md:grid-cols-[1.55fr_1fr] md:items-start">
        <!-- PLAYER CARD -->
        <div class="rounded-3xl border border-ink/10 bg-white/70 shadow-xl shadow-ink/10 backdrop-blur">
          <div class="flex items-center justify-between px-6 pt-6">
            <div class="flex items-center gap-3">
              <span class:list={[
                "inline-flex items-center gap-2 rounded-full px-3 py-1 text-xs font-medium",
                isLive ? "bg-rose text-ivory" : "bg-ink/5 text-ink/70"
              ]}>
                <span class:list={[
                  "h-2 w-2 rounded-full",
                  isLive ? "bg-ivory" : "bg-ink/30"
                ]}></span>
                {isLive ? "LIVE NOW" : "OFFLINE"}
              </span>

              <span class="text-xs text-ink/60">
                {isLive ? "Join the stream" : `Next live: ${nextLive}`}
              </span>
            </div>

            <a
              href="#chat"
              class="text-xs font-medium text-ink/60 hover:text-ink"
            >
              Jump to chat →
            </a>
          </div>

          <!-- 16:9 player area -->
          <div class="px-6 pt-4 pb-6">
            <div class="relative aspect-video overflow-hidden rounded-2xl bg-ink/5 ring-1 ring-ink/10">
              <!-- Replace this with your embed iframe when ready -->
              <div class="absolute inset-0 grid place-items-center">
                <div class="text-center">
                  <p class="brand-font text-2xl text-ink">Live Stream</p>
                  <p class="mt-2 text-sm text-ink/60">
                    {isLive ? "We’re live — come on in." : "Stream will appear here when we go live."}
                  </p>
                  <div class="mt-6 flex items-center justify-center gap-3">
                    <a
                      href="#watch"
                      class="inline-flex items-center justify-center rounded-xl bg-rose px-5 py-3 text-sm font-medium text-ivory shadow-lg shadow-rose/25 transition hover:translate-y-[-1px] hover:shadow-xl"
                    >
                      {isLive ? "Watch Live" : "Get Notified"}
                    </a>
                    <a
                      href="/about"
                      class="inline-flex items-center justify-center rounded-xl border border-ink/15 bg-white/60 px-5 py-3 text-sm font-medium text-ink transition hover:bg-white"
                    >
                      What to expect
                    </a>
                  </div>
                </div>
              </div>
            </div>

            <!-- player meta row -->
            <div class="mt-5 flex flex-wrap items-center justify-between gap-3">
              <div>
                <p class="text-sm font-semibold text-ink">{liveTitle}</p>
                <p class="text-sm text-ink/60">{liveSubtitle}</p>
              </div>

              <div class="flex items-center gap-2">
                <span class="inline-flex items-center rounded-full bg-ink/5 px-3 py-1 text-xs text-ink/70">
                  Live Q&A
                </span>
                <span class="inline-flex items-center rounded-full bg-ink/5 px-3 py-1 text-xs text-ink/70">
                  Wellness education
                </span>
                <span class="inline-flex items-center rounded-full bg-ink/5 px-3 py-1 text-xs text-ink/70">
                  Community
                </span>
              </div>
            </div>
          </div>
        </div>

        <!-- RIGHT PANEL -->
        <aside class="space-y-5">
          <div class="rounded-3xl border border-ink/10 bg-white/60 p-6 shadow-lg shadow-ink/5 backdrop-blur">
            <p class="text-xs font-semibold tracking-wide text-ink/60">TODAY</p>
            <h2 class="brand-font mt-2 text-3xl text-ink">
              {isLive ? "You’re right on time." : "Join the next session."}
            </h2>
            <p class="mt-3 text-sm leading-relaxed text-ink/65">
              Short teaching, real talk Q&A, and practical steps you can take this week — grounded in faith and integrity.
            </p>

            <div class="mt-5 rounded-2xl bg-ivory p-4 ring-1 ring-ink/10">
              <div class="flex items-start justify-between gap-3">
                <div>
                  <p class="text-sm font-semibold text-ink">
                    {isLive ? "Live now" : "Next live"}
                  </p>
                  <p class="text-sm text-ink/60">
                    {isLive ? "Tap Watch Live to join." : nextLive}
                  </p>
                </div>
                <span class="inline-flex items-center rounded-full bg-rose/12 px-3 py-1 text-xs font-medium text-rose">
                  {isLive ? "In progress" : "Scheduled"}
                </span>
              </div>

              <div class="mt-4 flex gap-3">
                <a
                  href="#watch"
                  class="flex-1 inline-flex items-center justify-center rounded-xl bg-rose px-4 py-3 text-sm font-medium text-ivory shadow-lg shadow-rose/25 transition hover:translate-y-[-1px]"
                >
                  {isLive ? "Watch Live" : "Set Reminder"}
                </a>
                <a
                  href="/app"
                  class="flex-1 inline-flex items-center justify-center rounded-xl border border-ink/15 bg-white/70 px-4 py-3 text-sm font-medium text-ink hover:bg-white"
                >
                  Open App
                </a>
              </div>
            </div>
          </div>

          <!-- Mini schedule -->
          <div class="rounded-3xl border border-ink/10 bg-white/60 p-6 shadow-lg shadow-ink/5 backdrop-blur">
            <div class="flex items-center justify-between">
              <p class="text-sm font-semibold text-ink">Upcoming</p>
              <a href="/live" class="text-sm text-ink/60 hover:text-ink">View all →</a>
            </div>

            <ul class="mt-4 space-y-3">
              <li class="flex items-center justify-between rounded-2xl bg-white/70 p-4 ring-1 ring-ink/10">
                <div>
                  <p class="text-sm font-semibold text-ink">Wholehearted Q&A</p>
                  <p class="text-xs text-ink/60">Thu • 8:00 PM ET</p>
                </div>
                <span class="text-xs font-medium text-ink/60">30 min</span>
              </li>

              <li class="flex items-center justify-between rounded-2xl bg-white/70 p-4 ring-1 ring-ink/10">
                <div>
                  <p class="text-sm font-semibold text-ink">Wellness Basics</p>
                  <p class="text-xs text-ink/60">Sun • 7:00 PM ET</p>
                </div>
                <span class="text-xs font-medium text-ink/60">25 min</span>
              </li>
            </ul>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- anchors for future sections -->
  <div id="watch"></div>
  <div id="chat"></div>
</BaseLayout>
